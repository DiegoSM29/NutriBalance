        return raw ? JSON.parse(raw) : null;
    }, []);

    const [ventas, setVentas] = useState([]);
    const [loading, setLoading] = useState(true);
    const [ventaExpandida, setVentaExpandida] = useState(null);

    const cargarVentas = useCallback(async () => {
